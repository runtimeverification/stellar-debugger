{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
      "--extensionDevelopmentPath=${workspaceFolder}",
      "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "${defaultBuildTask}"
    },
    {
      "name": "Soroban: Replay sample trace",
      "type": "soroban",
      "request": "launch",
      "rawTrace": "${workspaceFolder}/test/fixtures/add.trace.jsonl",
      "function": "add"
    }
  ]
}
