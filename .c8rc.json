{
  "all": true,
  "src": ["src"],
  "exclude-after-remap": true,
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.d.ts",
    "src/debugAdapter/types.ts",
    "src/sourcemap/SourceMapper.ts"
